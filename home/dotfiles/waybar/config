        , "sway/mode"
        //, "custom/media"
        ],
    "modules-center": [], // ["sway/window"],
    "modules-right":
        [ "idle_inhibitor"
        , "pulseaudio"
        , "network#wifi"
        , "network#ethernet"
        , "network#ethernet_direct"
        , "disk"
        , "cpu"
        , "memory"
        , "temperature"
        , "backlight"
        , "battery"
        , "custom/nix-updates"
        , "clock"
        , "tray"
        ],
