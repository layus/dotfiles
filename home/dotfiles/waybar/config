        "format": "<span font=\"Font Awesome 7 Free\">´öŞ</span> {:>3}%" // ´âë
    },
    "temperature": {
        "interval": 1,
        // "thermal-zone": 1,
        "hwmon-path": "/sys/class/hwmon/hwmon4/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "{temperatureC:2}┬░C {icon}",
        "format": "{icon} {temperatureC:2}┬░C",
        "format-icons":["<span font=\"Font Awesome 7 Free\">´őë</span>", "<span font=\"Font Awesome 7 Free\">´őë</span>", "<span font=\"Font Awesome 7 Free\">´őë</span>"] //["´Łź", "´őë", "´Łę"]
