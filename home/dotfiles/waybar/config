    },
    "clock#brussels": {
        "timezone": "Europe/Brussels",
        "interval": 1,
        "format": "{:%a %d %b %Y %T}",
        "tooltip-format": "{:%Z}"
    },
    "pulseaudio": {
        "scroll-step": 5, // %, can be a float
        "format": "{icon} {volume:3}%  {format_source}",
        "format-bluetooth": "{volume}% {icon}´Őö {format_source}",
        "format-bluetooth-muted": "´Üę {icon}´Őö {format_source}",
