            "default": ["<span font=\"Font Awesome 7 Free\">´ÇŽ</span>", "<span font=\"Font Awesome 7 Free\">´Çž</span>", "<span font=\"Font Awesome 7 Free\">´ÇĘ</span>"]
        },
        "on-click": "pavucontrol"
    },
    "custom/nix-updates": {
        "format": "{}",
        "return-type": "json",
        "interval": 30,
        "exec": "nix-updater-waybar",
        "on-click": "kitty --class nix-updater -e nix-updater-apply both"
    }
